{
  "separateMajorMinor": false,
  "pinVersions": false,
  "semanticCommits": true,
  "labels": [
    "target: minor",
    "action: merge"
  ],
  "baseBranches": [
    "master"
  ],
  "ignoreDeps": [
    "@types/node"
  ],
  "packageFiles": [
    "package.json"
  ],
  "packageRules": [
    {
      "excludePackagePatterns": [
        "^@angular/.*",
        "^@angular-devkit/.*",
        "^@schematics/.*"
      ],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!^0.",
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "schedule": [
        "after 1am on Thursday"
      ]
    }
  ]
}
